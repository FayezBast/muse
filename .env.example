# Use pk_test_/sk_test_ locally and pk_live_/sk_live_ in production.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=YOUR_SECRET_KEY
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/booking
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/booking

APP_URL=https://your-production-domain.com

RESEND_API_KEY=YOUR_RESEND_API_KEY
BOOKING_EMAIL_FROM="MUSE Booking <bookings@yourdomain.com>"
BOOKING_INSTRUCTOR_EMAIL=instructor@example.com
BOOKING_OWNER_EMAIL=owner@example.com
# Optional. Defaults to BOOKING_OWNER_EMAIL.
# BOOKING_REPLY_TO_EMAIL=hello@yourdomain.com

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Required in production for API abuse protection. Compatible with Upstash Redis REST.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_REDIS_REST_TOKEN

# Enable only if your hosted Postgres connection requires SSL.
# Use require for managed databases with a self-signed certificate chain.
# PGSSLMODE=require

# Staff access is controlled through Clerk metadata, not env email allowlists.
# Set user.publicMetadata.staffRole or user.privateMetadata.staffRole to "owner"
# or "instructor" in Clerk. Owners also receive instructor access.
